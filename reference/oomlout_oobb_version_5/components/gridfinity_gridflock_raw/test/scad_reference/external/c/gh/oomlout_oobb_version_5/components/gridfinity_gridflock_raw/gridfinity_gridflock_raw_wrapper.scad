    edge_puzzle_gap = effective_edge_puzzle_gap;
    edge_puzzle_magnet_border = effective_edge_puzzle_magnet_border;
    edge_puzzle_magnet_border_width = effective_edge_puzzle_magnet_border_width;
    edge_puzzle_height_female = effective_edge_puzzle_height_female;
